# VA QC App Environment Configuration
# Copy this to .env and fill in your values

# Google Configuration
# Get from Google Cloud Console - OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Or use existing token path
GOOGLE_TOKEN_PATH=/data/.openclaw/workspace/client_secret.json

# Spreadsheet
VA_QC_SPREADSHEET_ID=your_spreadsheet_id_here

# Email (Gmail SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Security
SECRET_KEY=generate-a-random-secret-key-here

# App Settings
DOMAIN=vulcanarc.co.za
DEBUG=false